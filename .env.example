# =============================================================================
# MeetMind — Umgebungsvariablen
# Kopiere diese Datei zu .env und fülle die Werte aus
# =============================================================================

# Datenbank
DATABASE_URL=postgresql+asyncpg://meetmind:meetmind_dev@localhost:5432/meetmind

# KI-Provider (MVP: local | Production: openai)
LLM_PROVIDER=local
TRANSCRIPTION_MODE=local
EMBEDDING_MODE=local

# OpenAI (nur für Production-Upgrade)
OPENAI_API_KEY=

# Ollama (MVP — lokal installiert)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Whisper (MVP — lokal)
WHISPER_MODEL=base
WHISPER_LANGUAGE=de

# Embeddings (MVP)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Auth — Clerk (https://dashboard.clerk.com)
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Monitoring — Sentry (https://sentry.io, Free Tier)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=500

# CORS (Frontend-URL)
CORS_ORIGINS=http://localhost:3000
